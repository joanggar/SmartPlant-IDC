    {
        "id": "4282f1431c579f05",
        "type": "function",
        "z": "02c1293b58f9c1cb",
        "name": "F_estadoTelegram",
        "func": "let temp = flow.get(\"temperature\");\nlet hum = flow.get(\"humidity\");\nlet soil = flow.get(\"soil\");\n\nlet status = \"\";\n\nif (soil < 30)\n    status = \"🔴 Necesita agua\";\nelse\n    status = \"🟢 Saludable, el riego es bueno\";\n\nmsg.payload = {\n    chatId: msg.originalMessage.chat.id,\n    type: \"message\",\n    content:\n        \"🌱 Smart Plant Status\\n\\n\" +\n        \"🌡 Temperatura: \" + temp + \" °C\\n\" +\n        \"💧 Humedad en aire: \" + hum + \" %\\n\" +\n        \"🌱 Humedad en suelo: \" + soil + \" %\\n\\n\" +\n        status\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 440,
        "wires": [
            [
                "257d2aeb6092f17b"
            ]
        ]
    },
    {
        "id": "aee68c9a7fec71fd",
        "type": "function",
        "z": "02c1293b58f9c1cb",
        "name": "F_saveData",
        "func": "flow.set(\"temperature\", msg.payload.temperature);\nflow.set(\"humidity\", msg.payload.humidity);\nflow.set(\"soil\", msg.payload.soil);\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],

    {
        "id": "fffd1f7d3c48cb40",
        "type": "function",
        "z": "02c1293b58f9c1cb",
        "name": "F_estadoPanel",
        "func": "let soil = msg.payload.soil;\n\nif (soil < 15) {\n    msg.payload = \"El Riego es urgente\";\n} else if (soil < 30) {\n    msg.payload = \"El Riego es recomendable\";\n} else if (soil > 90) {\n    msg.payload = \"Demasiada irrigación \";\n} else {\n    msg.payload = \"En condiciones optimas\";\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
